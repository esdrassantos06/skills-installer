{
  "name": "skills-installer",
  "version": "0.1.1",
  "description": "Desktop GUI to install agent skills from skills.sh in batch for Claude Code, Cursor, Codex, OpenCode, Antigravity, and other agents.",
  "main": "out/main/index.js",
  "license": "MIT",
  "author": "Esdras Santos",
  "homepage": "https://github.com/esdrassantos06/skills-installer",
  "repository": {
    "type": "git",
    "url": "https://github.com/esdrassantos06/skills-installer.git"
  },
  "bugs": {
    "url": "https://github.com/esdrassantos06/skills-installer/issues"
  },
  "keywords": [
    "claude-code",
    "agent-skills",
    "skills.sh",
    "electron",
    "installer",
    "ai-tools",
    "cursor",
    "antigravity"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:all": "electron-vite build && electron-builder -mw",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.6",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.6"
  }
}
