{
  "name": "skills-installer",
  "version": "0.1.2",
  "description": "Desktop GUI to install agent skills from skills.sh in batch for Claude Code, Cursor, Codex, OpenCode, Antigravity, and other agents.",
  "main": "out/main/index.js",
  "license": "MIT",
  "author": "Esdras Santos",
  "homepage": "https://github.com/esdrassantos06/skills-installer",
  "repository": {
    "type": "git",
    "url": "https://github.com/esdrassantos06/skills-installer.git"
  },
  "bugs": {
    "url": "https://github.com/esdrassantos06/skills-installer/issues"
  },
  "keywords": [
    "claude-code",
    "agent-skills",
    "skills.sh",
    "electron",
    "installer",
    "ai-tools",
    "cursor",
    "antigravity"
  ],
  "scripts": {
    "postinstall": "node -e \"const f='node_modules/electron/install.js';require('fs').existsSync(f)&&require('child_process').execFileSync(process.execPath,[f],{stdio:'inherit'})\"",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:all": "electron-vite build && electron-builder -mw",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^4.1.6",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.13",
    "vitest": "^4.1.6"
  }
}
